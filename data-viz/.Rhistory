library(tidyverse)
library(ComplexHeatmap)
library(data.table)
library(patchwork)
callset_long  <- fread("upset_long_callset.csv", header=FALSE, col.names=c("set","id"))
baseline_long <- fread("upset_long_baseline.csv", header=FALSE, col.names=c("set","id"))
# ---------------------------------------------------------------
# Helper: compute UpSet data from long format (pure data.table)
# ---------------------------------------------------------------
compute_upset_data <- function(dt, nintersects = 40) {
dt <- unique(dt)
mat <- dcast(dt, id ~ set, fun.aggregate = length, value.var = "set")
sets <- setdiff(names(mat), "id")
m <- as.matrix(mat[, ..sets])
m[m > 0] <- 1
# Compute set sizes
ss <- colSums(m)
names(ss) <- sets
# Compute intersection groups: each unique row pattern = one combination
# Create a string key for each row's membership pattern
pattern_keys <- apply(m, 1, paste, collapse = "")
pattern_tab  <- table(pattern_keys)
# Build the combination binary matrix (n_patterns x n_sets)
unique_patterns <- names(pattern_tab)
comb_mat_binary <- do.call(rbind, lapply(unique_patterns, function(p) {
as.integer(strsplit(p, "")[[1]])
}))
colnames(comb_mat_binary) <- sets
cs <- as.integer(pattern_tab)
names(cs) <- unique_patterns
# Remove the all-zero combination if it exists
row_sums <- rowSums(comb_mat_binary)
if (any(row_sums == 0)) {
keep_idx <- row_sums > 0
comb_mat_binary <- comb_mat_binary[keep_idx, , drop = FALSE]
cs <- cs[keep_idx]
}
# Keep top N by frequency
if (length(cs) > nintersects) {
ord_top <- order(-cs)[1:nintersects]
cs <- cs[ord_top]
comb_mat_binary <- comb_mat_binary[ord_top, , drop = FALSE]
}
# Order by descending frequency
ord <- order(-cs)
cs <- cs[ord]
comb_mat_binary <- comb_mat_binary[ord, , drop = FALSE]
list(
comb_sizes = cs,
set_sizes  = ss,
comb_mat   = comb_mat_binary,
sets       = names(ss),
n_comb     = length(cs)
)
}
# ---------------------------------------------------------------
# Main function: ggplot2-based UpSet with axis breaks & annotations
# ---------------------------------------------------------------
make_upset_gg <- function(dt,
nintersects = 40,
y_break = NULL,     # e.g. c(1500, 25000) for intersection
x_break = NULL,     # e.g. c(6000, 25000) for set size
bar_fill = "grey30",
dot_color = "grey30",
line_color = "grey30",
text_size = 2.8,
title = NULL) {
ud <- compute_upset_data(dt, nintersects)

cs <- cs[ord]
comb_mat_binary <- comb_mat_binary[ord, , drop = FALSE]
list(
comb_sizes = cs,
set_sizes  = ss,
comb_mat   = comb_mat_binary,
sets       = names(ss),
n_comb     = length(cs)
)
}
# ---------------------------------------------------------------
# Main function: ggplot2-based UpSet with axis breaks & annotations
# ---------------------------------------------------------------
make_upset_gg <- function(dt,
nintersects = 40,
y_break = NULL,     # e.g. c(1500, 25000) for intersection
x_break = NULL,     # e.g. c(6000, 25000) for set size
bar_fill = "grey30",
dot_color = "grey30",
line_color = "grey30",
text_size = 2.8,
title = NULL) {
ud <- compute_upset_data(dt, nintersects)
n_comb <- ud$n_comb
n_sets <- length(ud$sets)
# ----- 1. Top bar chart: Intersection sizes -----
bar_df <- data.frame(
x    = seq_len(n_comb),
size = as.integer(ud$comb_sizes)
)
p_top <- ggplot(bar_df, aes(x = x, y = size)) +
geom_col(fill = bar_fill, width = 0.7) +
geom_text(aes(label = size), vjust = -0.3,
size = text_size, color = "grey20") +
scale_x_continuous(limits = c(0.5, n_comb + 0.5), expand = c(0, 0),
breaks = NULL) +
scale_y_continuous(expand = expansion(mult = c(0, 0.12))) +
labs(y = "Intersection size", x = NULL) +
theme_minimal(base_size = 11) +
theme(
panel.grid.major.x = element_blank(),
panel.grid.minor   = element_blank(),
axis.text.x        = element_blank(),
axis.ticks.x       = element_blank(),
plot.margin        = margin(5, 5, 0, 5)
)
# Apply y-axis break if provided
if (!is.null(y_break) && length(y_break) == 2) {
p_top <- p_top +
ggbreak::scale_y_break(y_break, scales = 0.5,
ticklabels = NULL, space = 0.15)
}
# ----- 2. Dot matrix -----
# Build long-format for dots and connecting lines
dot_df <- expand.grid(x = seq_len(n_comb), y = seq_len(n_sets))
dot_df$set_name <- ud$sets[dot_df$y]
dot_df$active <- mapply(function(xi, yi) {
ud$comb_mat[xi, yi]
}, dot_df$x, dot_df$y)
# Segments connecting active dots in each combination
seg_list <- lapply(seq_len(n_comb), function(i) {
active_y <- which(ud$comb_mat[i, ] == 1)
if (length(active_y) >= 2) {
data.frame(x = i, ymin = min(active_y), ymax = max(active_y))
} else {
NULL
}
})
seg_df <- do.call(rbind, seg_list)
p_matrix <- ggplot() +
{if (!is.null(seg_df) && nrow(seg_df) > 0)
geom_segment(data = seg_df,
aes(x = x, xend = x, y = ymin, yend = ymax),
color = line_color, linewidth = 0.8)} +
geom_point(data = dot_df,
aes(x = x, y = y,
fill = factor(active),
size = factor(active)),
shape = 21, stroke = 0.3, color = "grey50") +
scale_fill_manual(values = c("0" = "grey85", "1" = dot_color),
guide = "none") +
scale_size_manual(values = c("0" = 2.5, "1" = 3.5), guide = "none") +
scale_x_continuous(limits = c(0.5, n_comb + 0.5), expand = c(0, 0)) +
scale_y_continuous(breaks = seq_len(n_sets), labels = ud$sets,
limits = c(0.5, n_sets + 0.5), expand = c(0, 0)) +
labs(x = NULL, y = NULL) +
theme_minimal(base_size = 11) +
theme(
panel.grid = element_blank(),
axis.text.x  = element_blank(),
axis.ticks.x = element_blank(),
plot.margin  = margin(0, 5, 5, 5)
)
# ----- 3. Left bar chart: Set sizes -----
set_df <- data.frame(
y    = seq_len(n_sets),
name = ud$sets,
size = as.integer(ud$set_sizes)
)
p_left <- ggplot(set_df, aes(x = size, y = y)) +
geom_col(fill = bar_fill, width = 0.7) +
geom_text(aes(label = size), hjust = -0.15,
size = text_size, color = "grey20") +
scale_y_continuous(breaks = seq_len(n_sets), labels = NULL,
limits = c(0.5, n_sets + 0.5), expand = c(0, 0)) +
scale_x_continuous(expand = expansion(mult = c(0, 0.15)),
position = "top") +
labs(x = "Set size", y = NULL) +
theme_minimal(base_size = 11) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.minor   = element_blank(),
axis.text.y        = element_blank(),
axis.ticks.y       = element_blank(),
plot.margin        = margin(0, 5, 5, 0)
)
# Apply x-axis break if provided
if (!is.null(x_break) && length(x_break) == 2) {
p_left <- p_left +
ggbreak::scale_x_break(x_break, scales = 0.5,
ticklabels = NULL, space = 0.15)
}
# ----- 4. Assemble with patchwork -----
# Empty spacer for top-left corner
p_empty <- plot_spacer()
layout <- (p_top | p_empty) / (p_matrix | p_left) +
plot_layout(
widths  = c(3, 1),
heights = c(1, 2)
)
if (!is.null(title)) {
layout <- layout + plot_annotation(title = title)
}
layout
}
# --- Callset UpSet ---
make_upset_gg(
callset_long,
nintersects = 40,
y_break = c(1500, 25000),
x_break = c(6000, 25000),
title   = "Callset"
)
install.packages("ggbreak")
# --- Callset UpSet ---
make_upset_gg(
callset_long,
nintersects = 40,
y_break = c(1500, 25000),
x_break = c(6000, 25000),
title   = "Callset"
)
library(tidyverse)
library(ComplexHeatmap)
library(data.table)
library(patchwork)
callset_long  <- fread("upset_long_callset.csv", header=FALSE, col.names=c("set","id"))
baseline_long <- fread("upset_long_baseline.csv", header=FALSE, col.names=c("set","id"))
# ---------------------------------------------------------------
# Helper: compute UpSet data from long format
# ---------------------------------------------------------------
compute_upset_data <- function(dt, nintersects = 40) {
dt <- unique(dt)
mat <- dcast(dt, id ~ set, fun.aggregate = length, value.var = "set")
sets <- setdiff(names(mat), "id")
m <- as.matrix(mat[, ..sets])
m[m > 0] <- 1
rownames(m) <- mat$id
cm <- make_comb_mat(m)
cs <- comb_size(cm)
# Keep top N by frequency
if (length(cs) > nintersects) {
keep <- names(sort(cs, decreasing = TRUE))[1:nintersects]
cm <- cm[, keep]
cs <- comb_size(cm)
}
# Combination membership matrix
comb_mat_binary <- t(as.matrix(cm))  # combinations x sets
ss <- set_size(cm)
# Order by descending frequency
ord <- order(-cs)
cs <- cs[ord]
comb_mat_binary <- comb_mat_binary[ord, , drop = FALSE]
list(
comb_sizes = cs,
set_sizes  = ss,
comb_mat   = comb_mat_binary,
sets       = names(ss),
n_comb     = length(cs)
)
}
